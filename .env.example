# ============================================================
# Polymarket Bot, .env
# Paper trading: you can leave almost everything blank.
# Interactive helper: polymarketbot setup-env
# ============================================================

# --- Mode (you choose these) ---
# false = fake money (recommended). true = real orders (dangerous)
LIVE_TRADING=false
# Emergency freeze. Or create empty file: data/KILL
KILL_SWITCH=false

# --- Wallet (LIVE only) ---
# HOW: MetaMask → Account details → Show private key (use a bot-only wallet)
PRIVATE_KEY=

# HOW: pick type, 0=EOA MetaMask, 1=proxy, 2=Safe, 3=deposit wallet
# Docs: https://docs.polymarket.com/trading/overview
SIGNATURE_TYPE=0

# HOW: polymarket.com → Settings → copy address that HOLDS your funds
# For SIGNATURE_TYPE=0 this is usually your own wallet address
FUNDER_ADDRESS=

# --- CLOB API keys (LIVE only) ---
# HOW: do NOT invent these. After PRIVATE_KEY is set, run:
#   polymarketbot derive-keys
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# --- Optional Telegram alerts ---
# HOW token: Telegram @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
# HOW chat id: message your bot, then open
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# --- Leave alone unless you know why ---
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
CONFIG_PATH=config/default.yaml
DB_PATH=data/bot.db
LOG_DIR=logs
KILL_SWITCH_FILE=data/KILL

